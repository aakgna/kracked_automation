# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ElevenLabs TTS
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# TikTok Developer App
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
# Must match the redirect URI registered in your TikTok developer app
TIKTOK_REDIRECT_URI=http://localhost:5000/api/auth/tiktok/callback

# SELF_ONLY for testing, PUBLIC_TO_EVERYONE once TikTok app is approved
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Pika Art via Fal.ai (https://fal.ai/dashboard)
FAL_KEY=...

# Kling AI dev platform (https://app.klingai.com — API keys page)
# New-style single API key (recommended — required for new models)
KLING_API_KEY=...
# Legacy access/secret pair (JWT auth) — only used if KLING_API_KEY is unset
KLING_ACCESS_KEY=...
KLING_SECRET_KEY=...

# Firebase Storage bucket for server-side media (defaults to <project_id>.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=...

# Firebase — path to your service account JSON (downloaded from Firebase console)
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# Flask session secret (any long random string)
FLASK_SECRET_KEY=change-me-to-something-random

# Background music volume (0.0 - 1.0)
MUSIC_VOLUME=0.15
